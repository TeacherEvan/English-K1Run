# ElevenLabs settings for local audio-generation scripts.
# Recommended: generate assets ahead of time instead of using browser-side TTS.

ELEVENLABS_API_KEY=your_api_key_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=E4IXevHtHpKGh0bvrPPr
ELEVENLABS_VOICE_ID_FR=EXAVITQu4EsNXjluf0k5
ELEVENLABS_VOICE_ID_JA=z9f4UheRPK2ZesPXd14b
# Set this to a verified Thai-capable voice from `npm run audio:list-voices`.
ELEVENLABS_VOICE_ID_TH=
ELEVENLABS_VOICE_ID_ZH_CN=cjVigY5qzO86Huf0OWal
ELEVENLABS_VOICE_ID_ZH_HK=wVcwzhXu7f0K5a1WoqaJ

# Optional: enable live ElevenLabs TTS in the browser during development.
# Leave blank for competition/staging/production builds.
VITE_ELEVENLABS_API_KEY=
